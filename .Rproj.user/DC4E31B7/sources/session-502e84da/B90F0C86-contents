\name{outliersHD-package}
\alias{outliersHD-package}
\docType{package}
\title{
Detection of Outliers in High Dimensional Data
}

\description{
Algorithms to detect high-dimensional outliers. The RMDP of Ro, Zou, Wang and Yin (2015),
the algorithm of Wilkinson that relies on nearest neighbours, and the DOD of Lee and Jeon (2025).
}

